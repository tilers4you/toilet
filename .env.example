# --- Telegram lead delivery ---
# Copy this file to .env.local for local testing, and set the same two values in
# Vercel → Project → Settings → Environment Variables for production.
# See TELEGRAM_LEADS_SETUP.md for how to obtain each value.

# Bot token from @BotFather (looks like 123456789:AAExampleExampleExampleExample)
TELEGRAM_BOT_TOKEN=

# Destination chat id where requests are delivered:
#  - a group/supergroup id (negative, e.g. -1001234567890)
#  - or your personal chat id (positive, e.g. 123456789)
TELEGRAM_CHAT_ID=
